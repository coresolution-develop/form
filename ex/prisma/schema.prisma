generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// 근무표(월간 그리드) 모델 — 멀티테넌트(조직별 orgId 스코프).
// 시트는 "직원(행) × 날짜(열)" 그리드, DB는 (employeeId, date, shift)로 정규화.
// ─────────────────────────────────────────────────────────────────────────

// 조직(테넌트) — 구 ScheduleConfig 싱글톤을 흡수 + 조직별 시트 바인딩/시크릿 보유.
model Org {
  id            String @id @default(cuid())
  slug          String @unique // URL/셀렉터용 식별자 (예: "default", "test")
  name          String // 표시명 (구 orgName)
  sheetId       String @default("") // 조직 전용 Google 스프레드시트 ID
  gridTabPrefix String @default("근무표") // 월별 탭 접두사 → `{prefix}-YYYY-MM`
  settingsTab   String @default("설정") // 근무형태 설정 탭 이름
  webhookSecret String @unique // Apps Script 웹훅 인증 = 테넌트 식별자
  activeMonth   String @default("2026-06") // 시트가 보여주는 활성 월 (YYYY-MM)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees   Employee[]
  assignments Assignment[]
  shiftTypes  ShiftType[]
  buckets     AggregateBucket[]
}

model Employee {
  id        String  @id @default(cuid())
  orgId     String
  org       Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  rank      String? // 직급 (대표/부장/…)
  dept      String? // 부서
  sortOrder Int     @default(0)

  // 동기화 메타
  source     String @default("sheet") // 'sheet' | 'service'
  syncStatus String @default("synced") // 'synced' | 'error' | 'pending'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments Assignment[]

  @@index([source])
  @@index([orgId, sortOrder])
}

model Assignment {
  id         String   @id @default(cuid())
  orgId      String
  org        Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  shift      String // 시프트 코드 (= ShiftType.code). 예) M, M/, /, Y, M9

  source     String @default("sheet")
  syncStatus String @default("synced")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date]) // 한 직원-한 날짜 = 한 칸
  @@index([orgId, date])
}

// 근무형태 사전 — 그리드의 "엔진". (조직, 코드)→라벨/색/집계기여 정의.
model ShiftType {
  orgId     String
  org       Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  code      String // "M", "M/", "/", "Y", "M9" …
  label     String // "평일근무", "오후반차" …
  bgColor   String @default("transparent")
  fgColor   String @default("")
  sortOrder Int    @default(0)

  // 집계 기여: [{ "bucket": "M", "weight": 1 }, ...]
  // 반차처럼 한 코드가 여러 버킷에 쪼개져 들어갈 수 있다(M/ → M 0.5 + Y 0.5).
  contributions Json @default("[]")

  @@id([orgId, code])
}

// 우측 합계 열 정의 (M / HD / / / Y …). (조직, 키) 단위라 조직별 열 구성이 자유롭다.
model AggregateBucket {
  orgId     String
  org       Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  key       String // "M", "HD", "OFF", "Y"
  label     String // 화면 표시명 (OFF는 "/")
  sortOrder Int    @default(0)

  @@id([orgId, key])
}
