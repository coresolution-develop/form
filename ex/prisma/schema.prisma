generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// 근무표(월간 그리드) 모델
// 시트는 "직원(행) × 날짜(열)" 그리드, DB는 (employeeId, date, shift)로 정규화.
// ─────────────────────────────────────────────────────────────────────────

model Employee {
  id        String  @id @default(cuid())
  name      String
  rank      String? // 직급 (대표/부장/…)
  dept      String? // 부서
  sortOrder Int     @default(0)

  // 동기화 메타
  source     String @default("sheet") // 'sheet' | 'service'
  syncStatus String @default("synced") // 'synced' | 'error' | 'pending'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments Assignment[]

  @@index([source])
}

model Assignment {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  shift      String // 시프트 코드 (= ShiftType.code). 예) M, M/, /, Y, M9

  source     String @default("sheet")
  syncStatus String @default("synced")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date]) // 한 직원-한 날짜 = 한 칸
  @@index([date])
}

// 근무형태 사전 — 그리드의 "엔진". 코드→라벨/색/집계기여 정의.
model ShiftType {
  code      String @id // "M", "M/", "/", "Y", "M9" …
  label     String // "평일근무", "오후반차" …
  bgColor   String @default("transparent")
  fgColor   String @default("")
  sortOrder Int    @default(0)

  // 집계 기여: [{ "bucket": "M", "weight": 1 }, ...]
  // 반차처럼 한 코드가 여러 버킷에 쪼개져 들어갈 수 있다(M/ → M 0.5 + Y 0.5).
  contributions Json @default("[]")
}

// 우측 합계 열 정의 (M / HD / / / Y …). 키도 설정값이라 열 추가가 자유롭다.
model AggregateBucket {
  key       String @id // "M", "HD", "OFF", "Y"
  label     String // 화면 표시명 (OFF는 "/")
  sortOrder Int    @default(0)
}

// 단일 설정 행(id=1 고정). 시트가 표현하는 "활성 월"과 조직 메타.
model ScheduleConfig {
  id          Int    @id @default(1)
  orgName     String @default("코어솔루션")
  activeMonth String @default("2026-06") // YYYY-MM — 시트가 보여주는 달
}
